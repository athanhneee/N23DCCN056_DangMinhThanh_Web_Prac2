NODE_ENV=production
PORT=3003
SERVICE_NAME=auth-service

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&schema=auth_service"

# Direct Postgres connection used by Prisma migrate deploy on Render.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=auth_service"

JWT_SECRET="replace-with-a-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"
